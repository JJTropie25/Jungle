{
  "expo": {
    "name": "Lagoon",
    "slug": "lagoon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Lagoon_icon_zoom.png",
    "scheme": "lagoon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#388c4a",
        "foregroundImage": "./assets/images/Lagoon_icon_zoom.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Lagoon_icon_zoom.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#388c4a",
          "dark": {
            "backgroundColor": "#388c4a"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
