{
  "expo": {
    "name": "Lagoon",
    "slug": "lagoon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Lagoon_icon_zoom.png",
    "scheme": "lagoon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.lagoon.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.lagoon.app",
      "adaptiveIcon": {
        "backgroundColor": "#388c4a",
        "foregroundImage": "./assets/images/Lagoon_icon_zoom.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.lagoon",
          "enableGooglePay": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Lagoon_icon_zoom.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#388c4a",
          "dark": {
            "backgroundColor": "#388c4a"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3ac596aa-bd3a-4534-ab7e-88d020cbde7c"
      }
    }
  }
}
